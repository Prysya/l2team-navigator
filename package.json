{
  "name": "l2team-navigator",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,css,json}\"",
    "preview": "vite preview",
    "update-skills": "node scripts/fetch-skills.mjs",
    "update-bosses": "node scripts/parse-wiki-bosses.mjs",
    "update-mw2": "node scripts/fetch-mw2-bosses.mjs",
    "update-data": "npm run update-skills && npm run update-bosses",
    "version:patch": "npm version patch -m \"chore: bump v%s\"",
    "version:minor": "npm version minor -m \"chore: bump v%s\"",
    "version:major": "npm version major -m \"chore: bump v%s\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepush": "npm run lint && npm run format:check && npm test && npm run build"
  },
  "dependencies": {
    "@saikus08/opencode-workbench": "^0.1.9",
    "@tanstack/react-table": "^8.21.3",
    "classnames": "^2.5.1",
    "normalize.css": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.8.7",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.2.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "sass": "^1.81.0",
    "sass-embedded": "^1.100.0",
    "typescript": "~5.6.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  }
}
