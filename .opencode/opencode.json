{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "typescript": {
      "enabled": true,
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    },
    "eslint": {
      "enabled": true,
      "command": ["vscode-eslint-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    }
  }
}